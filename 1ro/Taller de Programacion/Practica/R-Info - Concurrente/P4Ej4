programa p4Ej4
procesos
  proceso tareaUno (ES cantFlores:numero)
  comenzar
    mientras (HayFlorEnLaEsquina)
      tomarFlor
      cantFlores := cantFlores + 1
  fin
  proceso tareaDos (ES cantPapeles:numero)
  comenzar
    mientras(HayPapelEnLaEsquina)
      tomarPapel
      cantPapeles := cantPapeles + 1
  fin
areas
  aj : AreaP(1,1,1,1)
  cuadrante : AreaC (2,2,100,100)
robots
  robot jefe
  variables
    id,tarea:numero
    av,ca:numero
    e1,e2:boolean
  comenzar
    EnviarMensaje(1,t1)
    EnviarMensaje(2,t2)
    repetir 10
      Random(id,1,2)
      Random (av,2,100)
      Random(ca,2,100)
      Random(tarea,1,3)
      si (id = 1)
        EnviarMensaje(av,r1)
        EnviarMensaje(ca,r1)
        EnviarMensaje(tarea,r1)
      sino
        EnviarMensaje(av,r2)
        EnviarMensaje(ca,r2)
        EnviarMensaje(tarea,r2)
    tarea := 4
    EnviarMensaje(tarea,r1)
    EnviarMensaje(tarea,r2)
  fin
  robot trabajador
  variables
    id:numero
  comenzar
    RecibirMensaje(id,j)
  fin
variables
  j:jefe
  t1,t2: trabajador
comenzar
  AsignarArea(j,aj)
  AsignarArea(t1,cuadrante)
  AsignarArea(t2,cuadrante)
  Iniciar(j,1,1)
  Iniciar(t1,2,1)
  Iniciar(t2,3,1)
fin
